# AI Visibility Grader -- Backend Environment Variables
# Copy this file to .env and fill in your keys before running

# Groq (required) -- Llama 3.3 70B for query generation, parsing, recommendations
#                    Llama 3.1 8B as fast fallback
# Sign up free at https://console.groq.com
GROQ_API_KEY=gsk_...

# OpenRouter (optional) -- fallback when Groq is rate-limited
# Sign up free at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini (required) -- Gemini 1.5 Flash for LLM scoring
# Get a free key at https://aistudio.google.com
GOOGLE_API_KEY=AIza...

# Rainforest API (optional) -- for reliable live ASIN product lookups
# Sign up at https://www.rainforestapi.com/
# Without this key, the backend falls back to scraping Amazon directly.
# Scraping works locally but is often blocked on cloud IPs (Render, Railway).
RAINFOREST_API_KEY=

# CORS origin for the frontend (optional, defaults to * which allows all origins)
FRONTEND_URL=http://localhost:3000
