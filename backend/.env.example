# AI Visibility Grader — Backend Environment Variables
# Copy this file to .env and fill in your keys before running

# OpenAI (required) — used for QueryGenerator, Parser, Recommender, and GPT-4o LLM scoring
OPENAI_API_KEY=sk-...

# Anthropic (required) — used for Claude LLM scoring
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (required) — used for Gemini LLM scoring
GOOGLE_API_KEY=AIza...

# Rainforest API (optional) — for live ASIN product lookups
# Sign up at https://www.rainforestapi.com/
# If not set, the app uses a manual-entry fallback
RAINFOREST_API_KEY=

# CORS origin for the frontend (optional, defaults to *)
FRONTEND_URL=http://localhost:3000
